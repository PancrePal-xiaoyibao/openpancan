# OpenPanCan Environment Configuration
# Copy this file to .env and fill in the values

# === Gateway ===
GATEWAY_PORT=8000

# === Module Ports ===
VEP_SERVICE_PORT=8001
PHENOTYPE_RAG_PORT=8002
PHENOTYPE_SCORE_PORT=8003
PPI_SCORE_PORT=8004
VARIANT_RANK_PORT=8005
REPORT_PORT=8006
PANCANCER_SYSTEM_PORT=8007

# === LLM Configuration ===
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.1-70b-versatile

# === External APIs ===
ONCOKB_API_KEY=your_oncokb_api_key_here
PUBMED_API_KEY=your_pubmed_api_key_here

# === Database ===
DATABASE_URL=sqlite:///./opencancan.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/opencancan

# === Redis (optional) ===
REDIS_URL=redis://localhost:6379/0

# === VEP Configuration ===
VEP_CACHE_DIR=/data/vep_cache
VEP_FASTA_FILE=/data/vep_cache/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz
VEP_ASSEMBLY=GRCh38
VEP_PLUGINS=COSMIC,OncoKB

# === Data Paths ===
COSMIC_DATA_DIR=/data/cosmic
TCGA_DATA_DIR=/data/tcga
GTEx_DATA_DIR=/data/gtex
HPO_DATA_DIR=/data/hpo
STRING_DB_DIR=/data/string
DEPMAP_DATA_DIR=/data/depmap
