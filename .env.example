# =============================================================================
# OpenPanCan Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# See docs/database/current-configuration.md for detailed explanation

# -----------------------------------------------------------------------------
# Gateway Configuration
# -----------------------------------------------------------------------------
GATEWAY_PORT=8000
GATEWAY_TIMEOUT=120

# -----------------------------------------------------------------------------
# Module Ports
# -----------------------------------------------------------------------------
VEP_SERVICE_PORT=8001
PHENOTYPE_RAG_PORT=8002
PHENOTYPE_SCORE_PORT=8003
PPI_SCORE_PORT=8004
VARIANT_RANK_PORT=8005
REPORT_PORT=8006
PANCANCER_SYSTEM_PORT=8007

# -----------------------------------------------------------------------------
# LLM Configuration (Phenotype RAG + PanCancerSystem Chat)
# -----------------------------------------------------------------------------
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.1-70b-versatile
LLM_TIMEOUT=60

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# OncoKB (variant oncogenic classification)
ONCOKB_API_KEY=your_oncokb_api_key_here
ONCOKB_API_BASE_URL=https://www.oncokb.org/api/v1

# PubMed (literature search)
PUBMED_API_KEY=your_pubmed_api_key_here

# DGIdb (drug-gene interactions)
DGIDB_API_BASE_URL=https://dgidb.org/api/v2

# ClinicalTrials.gov
CLINICALTRIALS_API_BASE_URL=https://clinicaltrials.gov/api/v2

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (default, for development)
DATABASE_URL=sqlite+aiosqlite:///./openpancan.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/openpancan

# Redis (optional, for caching and job queues)
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-long-random-string-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8007,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# VEP Configuration
# -----------------------------------------------------------------------------
VEP_CACHE_DIR=./reference_data/vep_cache
VEP_FASTA_FILE=./reference_data/vep_cache/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz
VEP_ASSEMBLY=GRCh38
VEP_FORK=8
VEP_PLUGINS=COSMIC,OncoKB,ClinVar

# -----------------------------------------------------------------------------
# Reference Data Directories
# -----------------------------------------------------------------------------
COSMIC_DATA_DIR=./reference_data/cosmic
TCGA_DATA_DIR=./reference_data/tcga
GTEx_DATA_DIR=./reference_data/gtex
HPO_DATA_DIR=./reference_data/hpo
STRING_DB_DIR=./reference_data/string
DEPMAP_DATA_DIR=./reference_data/depmap
HGNC_DATA_DIR=./reference_data/hgnc
REACTOME_DATA_DIR=./reference_data/reactome
CLINVAR_DATA_DIR=./reference_data/clinvar

# -----------------------------------------------------------------------------
# Upload / Output Paths
# -----------------------------------------------------------------------------
UPLOAD_DIR=./temp_uploads
OUTPUT_DIR=./outputs
REPORT_OUTPUT_DIR=./outputs/reports
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Development Flags
# -----------------------------------------------------------------------------
DEBUG=false
MOCK_VEP=true  # Set to false when real VEP is configured
MOCK_LLM=false  # Set to true for rule-based fallback only
USE_GPU=false   # Enable GPU for embedding models