# =============================================================================
# OpenPanCan - Development Docker image with hot-reload
# =============================================================================

FROM python:3.12-slim

LABEL org.opencontainers.image.title="OpenPanCan Dev"
LABEL org.opencontainers.image.description="Pancreatic Cancer Genomic Analysis System - Development"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx \
    supervisor \
    curl \
    ca-certificates \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/log/supervisor /var/log/opencancan

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy Python dependencies manifest
COPY pyproject.toml ./

# Install Python dependencies
RUN uv pip install --system --no-cache fastapi uvicorn[standard] pydantic sqlalchemy aiosqlite httpx

# Copy backend code
COPY backend/ ./backend/

# Copy frontend code for hot-reload development
COPY frontend/ ./frontend/

# Install frontend dependencies
RUN cd frontend && npm install

# Copy dev configurations
COPY docker/nginx.conf /etc/nginx/sites-available/default
RUN mkdir -p /etc/nginx/conf.d \
    && cp /etc/nginx/sites-available/default /etc/nginx/conf.d/default.conf 2>/dev/null || true
COPY docker/supervisord.dev.conf /etc/supervisor/conf.d/opencancan.conf
COPY docker/entrypoint.dev.sh /entrypoint.sh

RUN chmod +x /entrypoint.sh && mkdir -p /data && chmod 777 /data

EXPOSE 8181 8007 5173

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV DATABASE_URL=sqlite:////data/opencancan.db

ENTRYPOINT ["/entrypoint.sh"]
